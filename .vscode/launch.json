{
 "version": "0.2.0",
 "configurations": [
  {
   "name": "Debug C",
   "type": "cppdbg",
   "request": "launch",
   "program": "${fileDirname}\\main.exe",
   "args": [],
   "stopAtEntry": false,
   "cwd": "${fileDirname}",
   "environment": [],
   "externalConsole": true,
   "MIMode": "gdb",
   "miDebuggerPath": "gdb",
   "setupCommands": [
    {
     "description": "Enable pretty-printing",
     "text": "-enable-pretty-printing",
     "ignoreFailures": true
    }
   ]
  }
 ]
}