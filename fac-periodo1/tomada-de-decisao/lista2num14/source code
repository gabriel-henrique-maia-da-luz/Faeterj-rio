#include <stdio.h>

//Faça um programa que capture a idade de uma pessoa e
//exiba a mensagem equivalente: não eleitor, eleitor obrigatório ou eleitor opcional.

//Modifique o programa para que envie uma mensagem aos eleitores opcionais menores de idade
//sobre a importância de votar.

int main()
{
    int idade;
    
    printf("Quantos anos você tem? ");
    scanf("%i", &idade);
    
    if (idade<=15) {
        printf("não eleitor");  
    } if (idade<=17) {
        printf("eleitor opcional");
    } else {
        printf("eleitor obrigatório");
    }

    return 0;
}